{
  "expo": {
    "name": "Tafasili",
    "slug": "tafasili",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tafasili-app-icon.png",
    "scheme": "tafasili",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Tafasili uses Face ID to protect your private activity and life records."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080F10",
        "foregroundImage": "./assets/images/tafasili-adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/tafasili-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/tafasili-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080F10",
          "dark": {
            "backgroundColor": "#080F10"
          }
        }
      ],
      "expo-secure-store",
      "expo-local-authentication",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
